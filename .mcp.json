{
  "mcpServers": {
    "berryer": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/index.js"],
      "env": {
        "PISTE_CLIENT_ID": "${PISTE_CLIENT_ID}",
        "PISTE_CLIENT_SECRET": "${PISTE_CLIENT_SECRET}",
        "PISTE_ENV": "${PISTE_ENV:-production}",
        "CACHE_DIR": "${CLAUDE_PLUGIN_ROOT}/.cache"
      }
    }
  }
}
