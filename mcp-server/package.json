{
  "name": "@demerys/berryer-mcp-server",
  "version": "0.1.0",
  "description": "MCP server pour le plugin berryer — expose les API Légifrance et BOFiP via PISTE.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "berryer-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -p . --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "undici": "^7.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
