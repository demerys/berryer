{
  "name": "@berryer/core",
  "version": "0.1.0",
  "description": "Core library partagé par les plugins de la suite Berryer (client PISTE OAuth, cache SQLite, schémas Zod, tools Légifrance).",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p .",
    "dev": "tsc -p . --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "undici": "^7.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "author": "DEMERYS INVESTMENT <contact@demerys.com> (https://demerys.com)",
  "license": "Apache-2.0"
}
